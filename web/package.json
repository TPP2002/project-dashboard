{
  "name": "claude-dashboard-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "多项目管理看板前端（Vite + Vue3 + Pinia + vue-router + echarts）。依赖仅装本目录 node_modules，绝不污染被监控项目。",
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
